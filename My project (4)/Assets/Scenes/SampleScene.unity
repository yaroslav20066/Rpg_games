      nextNode: 1
    - lied: 0
      text: "\u041A\u0442\u043E \u0442\u0430\u043A\u043E\u0439 \u0416\u0430\u043A?"
      nextNode: 1
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0422\u044B \u0434\u0430\u0436\u0435 \u043D\u0435 \u043F\u043E\u0441\u043C\u0435\u043B
      \u0443\u0437\u043D\u0430\u0442\u044C \u0435\u0433\u043E \u0438\u043C\u044F?
      \u0416\u0430\u043A \u0421\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u043D\u044B\u0439
      - \u0437\u043D\u0430\u0442\u043D\u044B\u0439 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0440\u043E\u0434\u043E\u043C \u043E\u0442\u0441\u044E\u0434\u0430. \u0418
      \u0442\u044B \u0435\u0433\u043E \u0443\u0431\u0438\u043B!"
    choices:
    - lied: 0
      text: "\u0421 \u0447\u0435\u0433\u043E \u0432\u044B \u0432\u0437\u044F\u043B\u0438,
        \u0447\u0442\u043E \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435
        \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u044F?"
      nextNode: 2
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u041F\u0430\u0440\u043D\u0438\u0448\u043A\u0430 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B
      \u043C\u0438\u043C\u043E \u043B\u0435\u0441\u0430 \u0438 \u0443\u0432\u0438\u0434\u0435\u043B,
      \u043A\u0430\u043A \u0416\u0430\u043A \u0441\u0440\u0430\u0437\u0438\u043B\u0441\u044F
      \u0441 \u0447\u0443\u0436\u0430\u043A\u043E\u043C \u0438 \u043A\u0430\u043A
      \u0435\u0433\u043E \u0443\u0431\u0438\u043B\u0438. \u0410 \u0442\u044B \u043E\u0447\u0435\u043D\u044C
      \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0448\u044C \u043F\u043E\u0434 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435. "
    choices:
    - lied: 0
      text: "\u041D\u0443 \u0434\u0430. \u042D\u0442\u043E \u0431\u044B\u043B \u044F.
        \u041D\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0443 \u043D\u0435\u0433\u043E
        \u0431\u044B\u043B \u0441\u043A\u0432\u0435\u0440\u043D\u044B\u0439."
      nextNode: 3
    - lied: 0
      text: "\u042D\u0442\u043E \u0431\u044B\u043B\u0438 \u0440\u0430\u0437\u0431\u043E\u0439\u043D\u0438\u043A\u0438.
        \u041E\u043D\u0438 \u043E\u0431\u043E\u0441\u043D\u0430\u0432\u0430\u043B\u0438\u0441\u044C
        \u0433\u0434\u0435-\u0442\u043E \u0442\u0443\u0442, \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443.
        \u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E \u0443
        \u043D\u0438\u0445 \u0442\u0430\u043C \u043B\u0430\u0433\u0435\u0440\u044C."
      nextNode: 4
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0421\u0435\u0439\u0447\u0430\u0441 \u0441\u043A\u0432\u0435\u0440\u043D\u044B\u043C
      \u043E\u043A\u0430\u0436\u0435\u0448\u044C\u0441\u044F \u0442\u044B. \u0425\u0412\u0410\u0422\u0410\u0419\u0422\u0415
      \u0415\u0413\u041E!"
    choices:
    - lied: 0
      text: "\u0417\u0430\u0440\u0430\u0437\u0430!"
      nextNode: -1
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0420\u0430\u0437\u0431\u043E\u0439\u043D\u0438\u043A\u0438? \u0417\u0434\u0435\u0441\u044C!?
      \u0415\u0441\u043B\u0438 \u044D\u0442\u043E \u0442\u0430\u043A, \u0442\u043E
      \u043D\u0443\u0436\u043D\u043E \u0441 \u043D\u0438\u043C\u0438 \u0440\u0430\u0441\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F.
      \u0422\u0430\u043A, \u043C\u044B \u0441\u0435\u0439\u0447\u0430\u0441 \u043F\u043E\u0439\u0434\u0435\u043C
      \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F, \u0430
      \u0442\u044B \u0441\u0442\u043E\u0439 \u0442\u0443\u0442. \u041A\u043E\u0433\u0434\u0430
      \u043C\u044B \u0432\u0435\u0440\u043D\u0435\u043C\u0441\u044F \u043C\u044B
      \u0440\u0435\u0448\u0438\u043C, \u0447\u0442\u043E \u0441 \u0442\u043E\u0431\u043E\u0439
      \u0434\u0435\u043B\u0430\u0442\u044C."
    choices:
    - lied: 1
      text: "\u041A\u0430\u043A \u0436\u0435\u043B\u0430\u0435\u0442\u0435"
      nextNode: -1
