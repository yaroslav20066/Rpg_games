  nodes:
  - speaker: "\u041F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430"
    dialogue: "\u0424\u0444\u0444, \u0430\u0439 \u043A\u0430\u043A \u0431\u043E\u043B\u044C\u043D\u043E.
      \u042D\u0439 \u0434\u043E\u0431\u0440\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
      \u043D\u0435 \u043F\u043E\u043C\u043E\u0436\u0435\u0442\u0435 \u043B\u0438
      \u0432\u044B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443 \u0432 \u0431\u0435\u0434\u0435?"
    choices:
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 0
      text: "\u0410 \u0442\u044B \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A
        \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430 \u044F \u0442\u0430\u043A
        \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u044E?"
      nextNode: 1
  - speaker: "\u041F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430"
    dialogue: "\u041E, \u0442\u0430\u043A \u044D\u0442\u043E \u043E\u043D \u0432\u0430\u0441
      \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B!? \u041A\u0430\u043A \u0436\u0435
      \u0445\u043E\u0440\u043E\u0448\u043E. \u042F \u0443\u0436\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E, \u0434\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
      \u0443\u043F\u0430\u043B \u0438 \u043D\u043E\u0433\u0443 \u0440\u0430\u0441\u0442\u044F\u043D\u0443\u043B.
      \u041A\u043E\u0435-\u043A\u0430\u043A \u0434\u043E\u0448\u0435\u043B \u0434\u043E
      \u043F\u043E\u043B\u044F, \u043D\u043E \u0434\u0430\u043B\u044C\u0448\u0435
      \u0438\u0434\u0442\u0438 \u043D\u0435 \u043C\u043E\u0433\u0443."
    choices:
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 1
      text: "\u041C\u0434\u0430, \u043D\u0435 \u043F\u043E\u0432\u0435\u0437\u043B\u043E
        \u0442\u0435\u0431\u0435. \u0412\u043E\u0442, \u0434\u0435\u0440\u0436\u0438
        \u0431\u0438\u043D\u0442."
      nextNode: 2
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 0
      text: "\u041C\u043D\u043E\u0433\u043E \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435
        \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043D\u0435\u0441\u0442\u0438,
        \u0440\u0430\u0437 \u0443\u0436 \u0442\u044B \u0442\u0443\u0442"
      nextNode: 3
  - speaker: "\u041F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430"
    dialogue: "\u041E\u0445, \u0442\u0430\u043A \u0443\u0436\u0435 \u043B\u0443\u0447\u0448\u0435.
      \u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0432\u0430\u043C, \u0434\u043E\u0431\u0440\u044B\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u0414\u0430\u0432\u0430\u0439\u0442\u0435,
      \u043F\u043E\u0439\u0434\u0435\u043C \u0443\u0436\u0435 \u0432 \u0446\u0435\u0432\u043A\u043E\u0432\u044C.
      \u0412\u0441\u0435 \u043C\u0435\u043D\u044F \u0443\u0436\u0435 \u0437\u0430\u0436\u0434\u0430\u043B\u0438\u0441\u044C."
    choices:
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 0
      text: "\u041F\u043E\u0448\u043B\u0438."
      nextNode: -1
  - speaker: "\u041F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430"
    dialogue: "\u041E\u043E, \u0435\u0441\u0442\u044C \u0442\u0430\u043A\u043E\u0435.
      \u0426\u0435\u043B\u044B\u0439 \u043C\u0435\u0448\u043E\u043A \u0441\u0435\u0440\u0435\u0431\u0440\u0430,
      \u043F\u0430\u0440\u0430 \u0441\u0442\u0440\u0435\u043B, \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0434\u0440\u0430\u0433\u043E\u0446\u0435... \u0410 \u0432\u044B \u0437\u0430\u0447\u0435\u043C
      \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442\u0435?"
    choices:
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 1
      text: "\u0420\u0430\u0434\u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430.
        \u0412\u043E\u0442 \u0432\u043E\u0437\u044C\u043C\u0438 \u0431\u0438\u043D\u0442."
      nextNode: 2
    - bad: 0
      silver: 0
      arrow: 0
      use_bandage: 0
      text: "\u0414\u0443\u043C\u0430\u044E \u0442\u0435\u043F\u0435\u0440\u044C
        \u044D\u0442\u043E \u043C\u043E\u0435."
      nextNode: 4
  - speaker: "\u041F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430"
    dialogue: "\u0427\u0442\u043E!? \u0412\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0442!
      \u042D\u0442\u043E \u0436\u0435 \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0438
      \u0426\u0435\u0440\u043A\u0432\u0438. \u041E\u043D\u0438 \u043D\u0443\u0436\u043D\u044B
      \u043D\u0443\u0436\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F. \u042F
      \u0438\u0445 \u043D\u0435 \u043E\u0442\u0434\u0430\u043C! \u041D\u0438\u043A\u0442\u043E
      \u043D\u0435 \u0441\u043C\u0435\u0435\u0442..."
    choices:
