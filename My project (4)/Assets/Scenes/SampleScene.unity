  nodes:
  - speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A"
    dialogue: "\u041E\u0445, \u0441\u043F\u0430\u0441\u0438\u0431\u043E \u0447\u0442\u043E
      \u043D\u0430\u0448\u0435\u043B \u043C\u043E\u0435\u0433\u043E \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430.
      \u0422\u0430\u043A \u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B,
      \u0447\u0442\u043E \u043E\u043D \u0432 \u0431\u0435\u0434\u0443 \u043F\u043E\u043F\u0430\u0434\u0435\u0442.
      \u0411\u043B\u0430\u0433\u043E, \u0447\u0442\u043E \u0432\u0441\u0435 \u043E\u0431\u043E\u0448\u043B\u043E\u0441\u044C. "
    choices:
    - text: "\u0420\u0430\u0434 \u043F\u043E\u043C\u043E\u0447\u044C. \u0422\u0435\u043F\u0435\u0440\u044C
        \u044F \u0434\u0440\u0443\u0433 \u0426\u0435\u0440\u043A\u0432\u0438?"
      nextNode: 1
  - speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A"
    dialogue: "\u041D\u0443 \u0435\u0441\u043B\u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0448\u044C
      \u0435\u0449\u0435 \u043E\u0434\u043D\u043E \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u0435,
      \u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u0438 \u0441\u0442\u0430\u043D\u0435\u0448\u044C.
      \u0412\u0438\u0434\u0438\u0448\u044C \u043B\u0438 \u044F \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B
      \u043F\u0440\u0438\u043D\u0435\u0441\u0435\u043D\u043D\u044B\u0435 \u0432\u0435\u0449\u0438
      \u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B, \u0447\u0442\u043E
      \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442 \u0433\u043B\u0430\u0432\u043D\u043E\u0439
      \u0432\u0435\u0449\u0438 - \u0417\u043E\u043B\u043E\u0442\u043E\u0433\u043E
      \u043A\u0440\u0435\u0441\u0442\u0430. \u041E\u043D\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
      \u043E \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438
      \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u043A \u0426\u0435\u0440\u043A\u0432\u0438,
      \u0442\u043E \u0435\u0441\u0442\u044C \u0431\u0435\u0437 \u043D\u0435\u0433\u043E
      \u0432\u044B \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u0440\u043E\u0439\u0442\u0438
      \u043C\u043E\u0441\u0442. \u042F \u043F\u044B\u0442\u0430\u043B\u0441\u044F
      \u0443\u0437\u043D\u0430\u0442\u044C \u0443 \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430,
      \u0433\u0434\u0435 \u043E\u043D \u043C\u043E\u0433 \u0435\u0433\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C,
      \u043D\u043E \u043E\u043D \u043C\u043D\u043E\u0433\u043E \u0433\u0434\u0435
      \u0431\u0440\u043E\u0434\u0438\u043B: \u0442\u043E \u0432 \u043B\u0435\u0441\u0443,
      \u0442\u043E \u0432 \u043F\u043E\u043B\u0435, \u0442\u043E \u0443 \u0434\u043E\u0440\u043E\u0433\u0438.
      \u041F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
      \u043D\u0443\u0436\u043D\u043E \u0438\u0441\u043A\u0430\u0442\u044C \u0432
      \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
      \u041C\u043E\u0436\u0435\u0448\u044C \u043B\u0438 \u0442\u044B \u043F\u043E\u043C\u043E\u0447\u044C? "
    choices:
    - text: "\u0415\u0441\u043B\u0438 \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438
        \u043D\u0435\u0433\u043E \u044F \u043F\u0435\u0440\u0435\u0439\u0434\u0443
        \u0447\u0435\u0440\u0435\u0437 \u043C\u043E\u0441\u0442, \u0442\u043E \u0434\u0430."
      nextNode: -1
