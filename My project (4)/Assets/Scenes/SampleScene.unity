  nodes:
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A"
    dialogue: "\u0421\u0442\u043E\u0439, \u043A\u0442\u043E \u0438\u0434\u0435\u0442?"
    choices:
    - text: "\u041E\u0431\u044B\u0447\u043D\u044B\u0439 \u043F\u0443\u0442\u043D\u0438\u043A,
        \u0438\u0434\u0443\u0449\u0438\u0439 \u0432 \u0433\u043E\u0440\u043E\u0434"
      nextNode: 1
    - text: "\u0421\u043E\u043B\u0434\u0430\u0442 \u041A\u0440\u043E\u0432\u0430\u0432\u043E\u0439
        \u0432\u043E\u0439\u043D\u044B, \u0433\u0435\u0440\u043E\u0439 \u0432 \u0431\u0438\u0442\u0432\u0435
        \u043F\u0440\u0438 \u041A\u043E\u0440\u0442\u0435\u043D\u0443\u0432\u0435"
      nextNode: 5
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0412 \u0433\u043E\u0440\u043E\u0434 \u0437\u043D\u0430\u0447\u0438\u0442
      \u0432\u044B \u0434\u0432\u0438\u0433\u0430\u0435\u0442\u0435\u0441\u044C,
      \u0430 \u043F\u0440\u043E\u043F\u0443\u0441\u043A \u0443 \u0432\u0430\u0441
      \u0435\u0441\u0442\u044C?"
    choices:
    - text: "\u0427\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0439\u0442\u0438
        \u043C\u043E\u0441\u0442 \u0442\u0435\u043F\u0435\u0440\u044C \u043D\u0443\u0436\u0435\u043D
        \u043F\u0440\u043E\u043F\u0443\u0441\u043A?"
      nextNode: 2
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0418\u043B\u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u043E \u0432
      \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u043F\u043B\u0430\u0442\u044B.
      \u0412\u043E\u0439\u043D\u0430 \u0432\u044B\u0442\u044F\u043D\u0443\u043B\u0430
      \u043C\u043D\u043E\u0433\u043E \u0434\u0435\u043D\u0435\u0433 \u0438\u0437
      \u043A\u0430\u0437\u043D\u044B \u0438 \u0442\u0435\u043F\u0435\u0440\u044C
      \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u043E \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F
      \u0438\u0445 \u0432\u0435\u0440\u043D\u0443\u0442\u044C. "
    choices:
    - text: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u0434\u0435\u043D\u0435\u0433
        \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442. \u041C\u043E\u0436\u0435\u0442
        \u0432\u044B \u043F\u0440\u043E\u044F\u0432\u0438\u0442\u0435 \u0441\u043D\u0438\u0441\u0445\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
        \u0432\u0435\u0442\u0435\u0440\u0430\u043D\u0443?"
      nextNode: 3
    - text: "\u0414\u0430 \u043A\u0430\u043A \u0432\u044B \u0441\u043C\u0435\u0435\u0442\u0435?!
        \u0414\u0430\u0439\u0442\u0435 \u043C\u043D\u0435 \u043F\u0440\u043E\u0439\u0442\u0438!
        \u042F \u0432\u0438\u0434\u0435\u043B \u043D\u0430 \u0432\u043E\u0439\u043D\u0435
        \u0442\u0430\u043A\u043E\u0435, \u0447\u0442\u043E \u0442\u0435\u0431\u0435
        \u0438 \u043D\u0435 \u0441\u043D\u0438\u043B\u043E\u0441\u044C!"
      nextNode: 3
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u041D\u0438\u043A\u0430\u043A\u0438\u0445 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439.
      \u0418\u0437\u0432\u0438\u043D\u0438\u0442\u0435, \u043D\u043E \u0442\u0430\u043A\u043E\u0432
      \u043F\u0440\u0438\u043A\u0430\u0437 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440\u0430
      \u0433\u0430\u0440\u043D\u0438\u0437\u043E\u043D\u0430. \u0411\u0435\u0437
      \u0441\u0435\u0440\u0435\u0431\u0440\u0430 \u0438\u043B\u0438 \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430,
      \u044F \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u0432\u0430\u0441
      \u043D\u0435 \u043C\u043E\u0433\u0443."
    choices:
    - text: ...
      nextNode: 4
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0412\u044B, \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u043C\u043E\u0436\u0435\u0442\u0435
      \u043F\u043E\u043F\u044B\u0442\u0430\u0442\u044C\u0441\u044F \u043F\u0440\u043E\u0431\u0438\u0442\u044C\u0441\u044F
      \u0447\u0435\u0440\u0435\u0437 \u043D\u0430\u0441, \u043D\u043E \u0431\u043E\u044E\u0441\u044C
      \u0432\u044B \u0431\u044B\u0441\u0442\u0440\u043E \u043E\u043A\u0430\u0436\u0435\u0442\u0435\u0441\u044C
      \u043D\u0430 \u0442\u043E\u043C \u0441\u0432\u0435\u0442\u0435, \u0447\u0435\u043C
      \u0432 \u0433\u043E\u0440\u043E\u0434\u0435."
    choices:
    - text: "\u0425\u043E\u0440\u043E\u0448\u043E, \u044F \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
        \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u044E"
      nextNode: -1
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0414\u0430\u0436\u0435 \u0442\u0430\u043A? \u041D\u0443 \u0442\u043E\u0433\u0434\u0430
      \u0441\u043A\u0430\u0436\u0438\u0442\u0435 \u043A\u0442\u043E \u0438\u0437
      \u0440\u044B\u0446\u0430\u0440\u0435\u0439 \u043F\u0440\u0438\u043D\u044F\u043B
      \u043F\u0435\u0440\u0432\u044B\u0439 \u0443\u0434\u0430\u0440 \u0432\u0440\u0430\u0433\u0430?"
    choices:
    - text: "\u042D\u0442\u043E \u0442\u0430\u0439\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
        \u043D\u0435\u043B\u044C\u0437\u044F \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
        \u043A\u043E\u043C\u0443 \u043F\u043E\u043F\u0430\u043B\u043E."
      nextNode: 6
    - text: "\u0421\u044D\u0440 \u0414\u0436\u0435\u0439\u043C\u0435 \u041A\u043E\u0441\u0442\u0435\u0440-\u0412\u0430\u043B\u044C\u0434\u0430\u0443,
        \u0440\u044B\u0446\u0430\u0440\u044C \u0442\u0440\u0435\u0445 \u043C\u0435\u0447\u0435\u0439."
      nextNode: 7
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u041A\u0430\u043A \u0438 \u043F\u043B\u0435\u0441\u0442\u0438 \u0447\u0443\u0448\u044C,
      \u0447\u0442\u043E \u0432\u044B \u0432\u043E\u0435\u0432\u0430\u043B\u0438.
      \u041D\u0443 \u0434\u0430 \u043B\u0430\u0434\u043D\u043E. \u0418\u0442\u0430\u043A..."
    choices:
    - text: ...
      nextNode: 1
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0412\u044B... \u043F\u0440\u0430\u0432\u044B. \u041F\u0440\u0438\u0432\u0435\u0441\u0442\u0432\u0443\u044E
      \u0432\u0430\u0441, \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D. \u0421\u043B\u044B\u0448\u0430\u043B,
      \u0447\u0442\u043E \u043C\u043D\u043E\u0433\u043E \u043D\u0430\u0448\u0438\u0445
      \u0432\u043E\u0438\u043D\u043E\u0432 \u0442\u0430\u043C \u043F\u043E\u0433\u0438\u0431\u043B\u043E."
    choices:
    - text: "\u0414\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E..."
      nextNode: 8
  - speaker: "\u0421\u0442\u0440\u0430\u0436\u043D\u0438\u043A "
    dialogue: "\u0421\u043E\u0436\u0430\u043B\u0435\u044E, \u043D\u043E \u044F \u043D\u0435
      \u043C\u043E\u0433\u0443 \u0432\u0430\u0441 \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C.
      \u0412\u0430\u043C \u043D\u0443\u0436\u0435\u043D \u043F\u0440\u043E\u043F\u0443\u0441\u043A..."
    choices:
    - text: ???
      nextNode: 2
