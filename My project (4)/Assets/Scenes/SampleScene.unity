    dialogue: "\u0422\u044B \u043D\u0430\u0448\u0435\u043B \u0435\u0433\u043E! \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044E
      \u0442\u0435\u0431\u044F! \u0422\u0435\u043F\u0435\u0440\u044C \u043C\u043E\u0438
      \u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u0438 \u043C\u043E\u0433\u0443\u0442
      \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u0432 \u0433\u043E\u0440\u043E\u0434."
    choices:
    - text: "\u042F \u043D\u0430\u0434\u0435\u044E\u0441\u044C \u043E\u043D\u0438
        \u043C\u043E\u0433\u0443\u0442 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F
        \u0441\u043E \u043C\u043D\u043E\u0439?"
      nextNode: 1
    - text: "\u0420\u0430\u0434 \u0431\u044B\u043B \u043F\u043E\u043C\u043E\u0447\u044C.
        \u041D\u0430\u0434\u0435\u044E\u0441\u044C \u044F \u0442\u0435\u043F\u0435\u0440\u044C
        \u0432\u0430\u0448 \u0434\u0440\u0443\u0433."
      nextNode: 1
  - speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u0435"
    dialogue: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E \u0434\u0440\u0443\u0433
      \u043C\u043E\u0439! \u0422\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u043B
      \u0441\u0438\u043B\u0443 \u0441\u0432\u043E\u0435\u0439 \u0432\u0435\u0440\u044B.
      \u0422\u0430\u043A\u0438\u0435 \u043A\u0430\u043A \u0432\u044B \u043E\u0447\u0435\u043D\u044C
      \u043D\u0443\u0436\u043D\u044B \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
      \u0446\u0435\u0440\u043A\u0432\u0438. \u0412\u043E\u0442 \u0432\u043E\u0437\u044C\u043C\u0438\u0442\u0435.
      \u042D\u0442\u0430 \u0434\u043E\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C
      \u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435. \u0421 \u043D\u0435\u0439
      \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0441\u043B\u0443\u0436\u0438\u0442\u044C
      \u0446\u0435\u0440\u043A\u0432\u0438 \u043D\u0430 \u0432\u0430\u0436\u043D\u044B\u0445
      \u043F\u043E\u0441\u0442\u0430\u0445. \u042D\u0442\u043E, \u043A\u043E\u043D\u0435\u0447\u043D\u043E
      \u0443\u0436\u0435 \u0432\u0430\u0448 \u0432\u044B\u0431\u043E\u0440.  "
    choices:
    - text: "\u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044E \u0432\u0430\u0441,
        \u041E\u0442\u0435\u0446. \u0412\u044B \u043E\u0447\u0435\u043D\u044C \u0432\u044B\u0440\u0443\u0447\u0438\u043B\u0438
        \u043C\u0435\u043D\u044F!"
      nextNode: -1
