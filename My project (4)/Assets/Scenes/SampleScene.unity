  nodes:
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0410 \u043D\u0443 \u0441\u0442\u043E\u0439! \u041A\u0430\u043A \u0442\u044B
      \u043F\u043E\u0441\u043C\u0435\u043B \u0443\u0431\u0438\u0442\u044C \u0416\u0430\u043A\u0430?!
