  nodes:
  - bandage: 0
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A"
    dialogue: "\u041F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E,
      \u0421\u044B\u043D \u043C\u043E\u0439. \u0427\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
      \u0442\u0435\u0431\u044F \u0441\u044E\u0434\u0430?"
    choices:
    - text: "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439, \u041E\u0442\u0435\u0446.
        \u0412 \u0433\u043E\u0440\u043E\u0434 \u0434\u0432\u0438\u0433\u0430\u043B\u0441\u044F
        \u044F, \u0447\u0442\u043E\u0431\u044B \u0436\u0438\u0437\u043D\u044C \u0445\u043E\u0440\u043E\u0448\u043E
        \u043E\u0431\u0443\u0441\u0442\u0440\u043E\u0438\u0442\u044C, \u043D\u043E
        \u0441\u0442\u0440\u0430\u0436\u0430 \u043D\u0435 \u0434\u0430\u0435\u0442
        \u043F\u0440\u043E\u0445\u043E\u0434\u0430."
      nextNode: 1
  - bandage: 0
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A "
    dialogue: "\u0425\u043C, \u0438\u0434\u0442\u0438 \u0437\u0430 \u043B\u0443\u0447\u0448\u0435\u0439
      \u0436\u0438\u0437\u043D\u044C\u044E \u044D\u0442\u043E \u0431\u043B\u0430\u0433\u043E\u0435
      \u0434\u0435\u043B\u043E. \u042F \u0432\u043E\u0442 \u0442\u043E\u0436\u0435
      \u0440\u0435\u0448\u0438\u043B \u0441\u0432\u043E\u0438\u0445 \u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u0435\u0439
      \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C \u0432 \u0433\u043E\u0440\u043E\u0434
      \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0443 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
      \u0446\u0435\u0440\u043A\u0432\u0438. \u0422\u0430\u043C \u043E\u043D\u0438
      \u043C\u043D\u043E\u0433\u043E \u0447\u0435\u043C\u0443 \u043D\u0430\u0443\u0447\u0430\u0442\u0441\u044F,
      \u0447\u0435\u043C \u0437\u0434\u0435\u0441\u044C. "
    choices:
    - text: "\u0422\u043E \u0435\u0441\u0442\u044C \u0432\u044B \u0442\u043E\u0436\u0435
        \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0435\u0441\u044C
        \u0432 \u0433\u043E\u0440\u043E\u0434? \u0412\u043E\u0437\u044C\u043C\u0435\u0442\u0435
        \u043C\u0435\u043D\u044F \u0441 \u0441\u043E\u0431\u043E\u0439, \u042F \u0433\u043E\u0442\u043E\u0432
        \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u0442\u044C."
      nextNode: 2
    - text: "\u0420\u0430\u0437 \u0443\u0436 \u0443 \u043D\u0430\u0441 \u043E\u0434\u043D\u0430
        \u0446\u0435\u043B\u044C, \u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u0438\u043C\u0438\u0442\u0435
        \u043C\u0435\u043D\u044F? \u0423\u0432\u0435\u0440\u0435\u043D, \u043E\u0445\u0440\u0430\u043D\u0430
        \u0432\u0430\u043C \u043D\u0435 \u043F\u043E\u043C\u0435\u0448\u0430\u0435\u0442."
      nextNode: 3
  - bandage: 0
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A "
    dialogue: "\u041F\u0440\u043E\u0441\u0442\u0438, \u043D\u043E \u043D\u0435 \u043A\u0430\u043A\u0438\u0435
      \u0434\u0435\u043D\u044C\u0433\u0438 \u043D\u0435 \u0437\u0430\u0441\u0442\u0430\u0432\u044F\u0442
      \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F \u043F\u0440\u0438\u0432\u0435\u043B\u0435\u0433\u0438\u044F\u043C\u0438
      \u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0426\u0435\u0440\u043A\u0432\u0438.
      \u0418\u043C\u0438 \u043C\u043E\u0433\u0443\u0442 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0442\u043E\u043B\u044C\u043A\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u043E
      \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
      \u0438\u043B\u0438 \u0442\u043E\u0442, \u043A\u0442\u043E \u043F\u043E\u043C\u043E\u0433
      \u0426\u0435\u0440\u043A\u0432\u0438. "
    choices:
    - text: "\u0427\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u0434\u0435\u043B\u0430\u0442\u044C?"
      nextNode: 4
  - bandage: 0
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A "
    dialogue: "\u041D\u0435 \u0434\u0443\u043C\u0430\u044E, \u0447\u0442\u043E \u043A\u0442\u043E-\u0442\u043E
      \u043F\u043E \u043F\u0443\u0442\u0438 \u043D\u0430\u043F\u0430\u0434\u0435\u0442
      \u043D\u0430 \u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0426\u0435\u0440\u043A\u0432\u0438,
      \u043D\u043E \u0435\u0441\u043B\u0438 \u0442\u044B \u043F\u043E\u043C\u043E\u0436\u0435\u0448\u044C
      \u043D\u0430\u043C, \u044F \u043F\u043E\u0434\u0443\u043C\u0430\u044E \u043D\u0430\u0434
      \u0442\u0432\u043E\u0435\u0439 \u043F\u0440\u043E\u0441\u044C\u0431\u043E\u0439."
    choices:
    - text: "\u0425\u043E\u0440\u043E\u0448\u043E. \u0427\u0442\u043E \u043D\u0443\u0436\u043D\u043E
        \u0441\u0434\u0435\u043B\u0430\u0442\u044C?"
      nextNode: 4
  - bandage: 0
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A "
    dialogue: "\u0412\u0438\u0434\u0438\u0448\u044C \u043B\u0438, \u0434\u0435\u0440\u0435\u0432\u043D\u044F
      \u0443 \u043D\u0430\u0441 \u0431\u0435\u0434\u043D\u0430\u044F \u0438 \u0434\u0435\u0440\u0436\u0430\u0442\u044C
      \u0432\u0441\u0435 \u0434\u0440\u0430\u0433\u043E\u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438
      \u0432 \u0446\u0435\u0440\u043A\u0432\u0438 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
      \u043E\u043F\u0430\u0441\u043D\u043E. \u041C\u044B \u0445\u0440\u0430\u043D\u0438\u043B\u0438
      \u0438\u0445 \u0432 \u043B\u0435\u0441\u0443 \u0437\u0430 \u043F\u043E\u043B\u0435\u043C.
      \u0422\u0435\u043F\u0435\u0440\u044C \u043E\u043D\u0438 \u0431\u0443\u0434\u0443\u0442
      \u043D\u0443\u0436\u043D\u0435\u0435 \u043C\u043E\u0438\u043C \u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u044F\u043C
      \u0432 \u0433\u043E\u0440\u043E\u0434\u0435, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u044F \u043F\u043E\u0441\u043B\u0430\u043B \u0441\u0432\u043E\u0435\u0433\u043E
      \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430 \u0437\u0430\u0431\u0440\u0430\u0442\u044C
      \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438, \u043D\u043E \u043E\u043D
      \u0442\u0430\u043A \u0438 \u043D\u0435 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F. "
    choices:
    - text: "\u0421\u0434\u0435\u043B\u0430\u044E, \u0432\u0441\u0435 \u0447\u0442\u043E
        \u0441\u043C\u043E\u0433\u0443, \u043D\u043E \u043E\u0431\u0435\u0449\u0430\u0442\u044C
        \u043D\u0435 \u043C\u043E\u0433\u0443."
      nextNode: 5
  - bandage: 1
    speaker: "\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A "
    dialogue: "\u0418 \u0435\u0449\u0435 \u043A\u043E\u0435-\u0447\u0442\u043E. \u041F\u043E\u043C\u043E\u0448\u043D\u0438\u043A
      \u043C\u043E\u0439 \u0441\u043E \u0441\u043E\u0438\u043C\u0438 \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044F\u043C\u0438
      \u0441\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0445\u043E\u0440\u043E\u0448\u043E,
      \u043D\u043E \u043E\u043D \u043F\u043E\u0440\u043E\u0439 \u0431\u044B\u0432\u0430\u0435\u0442
      \u043D\u0435\u0440\u044F\u0448\u043B\u0438\u0432. \u0411\u043E\u044E\u0441\u044C,
      \u043E\u043D \u043F\u043E\u043F\u0430\u043B \u0432 \u0431\u0435\u0434\u0443.
      \u0412\u043E\u0442, \u0432\u043E\u0437\u044C\u043C\u0438. \u0421\u0435\u0440\u0434\u0446\u0435\u043C
      \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E, \u0447\u0442\u043E \u043E\u043D\u043E
      \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F."
    choices:
    - text: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u041E\u0442\u0435\u0446.
        \u041F\u043E\u043F\u044B\u0442\u0430\u044E\u0441\u044C \u0435\u0433\u043E
        \u043D\u0430\u0439\u0442\u0438."
      nextNode: -1
