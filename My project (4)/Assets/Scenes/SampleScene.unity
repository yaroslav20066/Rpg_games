  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446"
    dialogue: "\u0410, \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0447\u0443\u0442\u044C
      \u043D\u0435 \u0437\u0430\u0431\u044B\u043B. \u0421\u0435\u0439\u0447\u0430\u0441
      \u043F\u043E\u043A\u0430\u0436\u0443. \u0421\u043B\u0443\u0448\u0430\u0439,
      \u0435\u0441\u043B\u0438 \u043D\u0435 \u0441\u0435\u043A\u0440\u0435\u0442,
