      \u0434\u043E\u0431\u0440\u043E \u0426\u0435\u0440\u043A\u0432\u0438 \u0437\u0430\u0431\u0440\u0430\u043B
      \u0441\u0435\u0431\u0435! "
    choices:
    - lied: 0
      text: "\u0421 \u0447\u0435\u0433\u043E \u0432\u044B \u0432\u0437\u044F\u043B\u0438,
        \u0447\u0442\u043E \u044D\u0442\u043E \u044F?"
      nextNode: 2
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D"
    dialogue: "\u041F\u0430\u0440\u043D\u0438\u0448\u043A\u0430 \u0440\u044F\u0434\u043E\u043C
      \u0441 \u043F\u043E\u043B\u0435\u043C \u043F\u0440\u043E\u0431\u0435\u0433\u0430\u043B
      \u0438 \u0443\u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u0447\u0443\u0436\u0430\u043A
      \u0443\u0431\u0438\u043B \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430
      \u043D\u0430\u0448\u0435\u0433\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430.
      \u041A\u0430\u043A \u0432\u0438\u0434\u0438\u0448\u044C, \u0438\u0437 \u0447\u0443\u0436\u0430\u043A\u043E\u0432
      \u0441 \u043E\u0440\u0443\u0436\u0438\u0435\u043C \u0442\u0443\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
      \u0442\u044B!"
    choices:
    - lied: 0
      text: "\u0418 \u0447\u0442\u043E \u0432\u044B \u043C\u043D\u0435 \u0441\u0434\u0435\u043B\u0430\u0435\u0442\u0435?
        \u041F\u0448\u0435\u043D\u043E\u043C \u0437\u0430\u043A\u0438\u0434\u0430\u0435\u0442\u0435?"
      nextNode: 3
    - lied: 0
      text: "\u0412\u043E\u043E\u0431\u0449\u0435-\u0442\u043E \u0442\u0443\u0442
        \u043C\u043D\u043E\u0433\u043E \u0447\u0443\u0436\u0430\u043A\u043E\u0432
        \u0441 \u043E\u0440\u0443\u0436\u0438\u0435\u043C \u0431\u0440\u043E\u0434\u044F\u0442.
        \u0412\u0440\u0435\u043C\u0435\u043D\u0430 \u0442\u0430\u043A\u0438\u0435.
        \u0414\u0430 \u0438 \u043D\u0435 \u0431\u043B\u0430\u0433\u043E\u0435 \u044D\u0442\u043E
        \u0434\u0435\u043B\u043E \u043E\u0431\u0432\u0438\u043D\u044F\u0442\u044C
        \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u043D\u043E\u0433\u043E."
      nextNode: 5
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D"
    dialogue: "\u041D\u0435 \u043F\u0448\u0435\u043D\u043E\u043C, \u0430 \u0432\u0438\u043B\u0430\u043C\u0438
      \u0438 \u0434\u0443\u0431\u0438\u043D\u0430\u043C\u0438. \u0411\u0420\u0410\u0422\u042C\u042F!
      \u0425\u0412\u0410\u0422\u0410\u0419\u0422\u0415 \u0415\u0413\u041E!"
    choices:
    - lied: 0
      text: "\u0412\u043E\u0442 \u0447\u0435\u0440\u0442!"
      nextNode: -1
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0410\u0433\u0430 \u0437\u043D\u0430\u0447\u0438\u0442 \u0441\u043E\u0437\u043D\u0430\u0435\u0448\u044C\u0441\u044F!
      \u0425\u0412\u0410\u0422\u0410\u0419\u0422\u0415 \u0415\u0413\u041E, \u0411\u0420\u0410\u0422\u042C\u042F!"
    choices:
    - lied: 0
      text: "\u0412\u043E\u0442 \u0447\u0435\u0440\u0442!"
      nextNode: -1
  - speaker: "\u041A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0438\u043D "
    dialogue: "\u0425\u043C\u043C... \u0425\u043E\u0442\u044C \u0442\u044B \u0438
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u0435\u043D, \u043D\u043E
      \u0442\u044B \u0434\u0435\u043B\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0448\u044C.
      \u0425\u043E\u0440\u043E\u0448\u043E, \u043C\u044B \u0441\u0435\u0439\u0447\u0430\u0441
      \u043F\u043E\u0445\u043E\u0434\u0438\u043C \u043F\u043E \u043B\u0435\u0441\u0443,
      \u0431\u0443\u0434\u0435\u043C \u0438\u0441\u043A\u0430\u0442\u044C \u0443\u0431\u0438\u0439\u0446\u0443.
      \u041F\u043E\u0442\u043E\u043C \u0432\u0435\u0440\u043D\u0435\u043C\u0441\u044F
      \u0438 \u0431\u0443\u0434\u0435\u043C \u0440\u0435\u0448\u0430\u0442\u044C,
      \u0447\u0442\u043E \u0441 \u0442\u043E\u0431\u043E\u0439 \u0434\u0435\u043B\u0430\u0442\u044C."
    choices:
    - lied: 1
      text: "\u041D\u0443 \u043A\u043E\u043D\u0435\u0447\u043D\u043E! \u0411\u0443\u0434\u0435\u0442
        \u043F\u043E \u0432\u0430\u0448\u0435\u043C\u0443."
      nextNode: -1
