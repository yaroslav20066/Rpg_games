  nodes:
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u0412\u043E\u0442 \u0436\u0435\u0448\u044C \u0447\u0435\u0440\u0442\u0438.
      \u0412\u0441\u0435 \u0437\u0430\u0431\u0440\u0430\u043B\u0438! \u0414\u0430\u0436\u0435
      \u043C\u0435\u0442\u0430\u043B\u043B \u0441 \u043F\u0440\u0438\u043C\u0435\u0441\u044F\u043C\u0438
      \u0438\u0437 \u0411\u044D\u0434\u0441\u0432\u043E\u0440\u0434\u0430! \u0412\u043E\u0442
      \u0437\u0430\u0447\u0435\u043C \u043E\u043D \u0438\u043C?! (\u041E\u0431\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F)
      \u0427\u0442\u043E, \u0440\u0435\u0448\u0438\u043B\u0438 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C
      \u043D\u0430\u0447\u0430\u0442\u043E\u0435!?"
    choices:
    - bad: 0
      text: "\u0427\u0435\u0433\u043E?! \u0412\u044B \u043E \u0447\u0435\u043C?"
      nextNode: 1
    - bad: 0
      text: "\u0423 \u0432\u0430\u0441 \u0447\u0442\u043E-\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
      nextNode: 1
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u0410, \u0432\u044B \u043D\u0435 \u0438\u0437 \u0432\u043E\u0440\u043E\u0432?
      \u0422\u043E\u0433\u0434\u0430 \u043B\u0430\u0434\u043D\u043E. \u0411\u0435\u0434\u0430
      \u0441\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C! \u0415\u0445\u0430\u043B
      \u044F \u0432 \u0433\u043E\u0440\u043E\u0434 \u0437\u043D\u0430\u0447\u0438\u0442,
      \u0447\u0442\u043E\u0431\u044B \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u0441\u0432\u043E\u044E \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u044E,
      \u043A\u0430\u043A \u0442\u0443\u0442 \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
      \u044D\u0442\u0438 \u0447\u0435\u0440\u0442\u0438, \u0443\u0433\u0440\u043E\u0436\u0430\u044E\u0442
      \u0438 \u0437\u0430\u0431\u0438\u0440\u0430\u044E\u0442 \u043F\u043E\u0447\u0442\u0438
      \u0432\u0441\u0435! \u0418 \u044D\u0442\u043E \u0440\u044F\u0434\u043E\u043C
      \u0441 \u043C\u043E\u0435\u0439 \u0440\u043E\u0434\u043D\u043E\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0435\u0439!"
    choices:
    - bad: 0
      text: "\u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E
        \u0443 \u043D\u0438\u0445 \u0433\u0434\u0435-\u0442\u043E \u0440\u044F\u0434\u043E\u043C
        \u043B\u0430\u0433\u0435\u0440\u044C..."
      nextNode: 4
    - bad: 0
      text: "\u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B \u0432\u0441\u0435\u0433\u0434\u0430
        \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u0438.
        \u0422\u0430\u043A\u043E\u0432 \u043C\u0438\u0440."
      nextNode: 2
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u041E\u0439, \u0431\u0443\u0434\u044C \u043F\u0440\u043E\u043A\u043B\u044F\u0442\u0430
      \u044D\u0442\u0430 \u0432\u043E\u0439\u043D\u0430! \u0418\u0437-\u0437\u0430
      \u043D\u0435\u0435 \u0443 \u043C\u0435\u043D\u044F \u0432\u0441\u044F \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u044F
      \u0443\u0448\u043B\u0430 \u0432 \u0443\u043F\u0430\u0434\u043E\u043A! \u041F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
      \u043B\u0435\u0437\u0442\u044C \u0432 \u0434\u043E\u043B\u0433\u0438 \u0438
      \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0447\u0430\u0441\u0442\u044C
      \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430. \u0410 \u0432\u0435\u0434\u044C
      \u0440\u0430\u043D\u044C\u0448\u0435 \u0443 \u043C\u0435\u043D\u044F \u0431\u044B\u043B\u0430
      \u043E\u0431\u0448\u0438\u0440\u043D\u0430\u044F \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u044F
      \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u0433\u043E\u0440\u043E\u0434\u0430\u0445,
      \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0438 \u0432 \u041A\u043E\u0440\u043D\u0435\u0432\u0443\u043B\u0435.
      \u042F \u0434\u0430\u0436\u0435 \u0438\u043C\u0435\u043B \u0434\u043E\u043C
      \u0432 \u0435\u0433\u043E \u043E\u043A\u0440\u0435\u0441\u043D\u043E\u0441\u0442\u044F\u0445.
      \u0410 \u043F\u043E\u0442\u043E\u043C \u043F\u0440\u0438\u0448\u043B\u043E
      \u0432\u043E\u0439\u0441\u043A\u043E \u0438 \u0432\u0441\u0435 \u0441\u043E\u0436\u0433\u043B\u043E!"
    choices:
    - bad: 0
      text: "\u041F\u043E\u0445\u043E\u0434\u0443 \u043C\u044B \u043E\u0431\u0430
        \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0438 \u0441\u0432\u043E\u0438
        \u0434\u043E\u043C\u0430 \u0438\u0437-\u0437\u0430 \u0432\u043E\u0439\u043D\u044B."
      nextNode: 3
    - bad: 0
      text: "\u0422\u044B \u0437\u043D\u0430\u0435\u0448\u044C \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
        \u043F\u0440\u043E \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0438? \u0421\u0442\u0440\u0430\u0436\u0430
        \u0438\u0445 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0443 \u043C\u043E\u0441\u0442\u0430."
      nextNode: 5
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u0410, \u0432\u044B \u0442\u043E\u0436\u0435 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0438
      \u0438\u0437-\u0437\u0430 \u043D\u0435\u0435. \u041D\u0443 \u0434\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u043D\u0430\u0448
      \u043A\u043B\u0430\u043D \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u0432\u0448\u0438\u0445.
      \u0410 \u0440\u0430\u0437\u0431\u043E\u0439\u043D\u0438\u043A\u043E\u0432 \u0442\u0435\u043F\u0435\u0440\u044C
      \u043A\u0430\u043A \u043A\u0440\u044B\u0441. \u041F\u0440\u0438 \u0447\u0435\u043C
      \u0441\u0442\u0440\u0430\u0436\u0430 \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
      \u0433\u043E\u0440\u043E\u0434\u043E\u0432 \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435 \u0434\u0430\u043B\u0430\u0435\u0442! \u0412\u0438\u0434\u0438\u0442\u0435
      \u043B\u0438 \u044D\u0442\u043E \u043D\u0435 \u0438\u0445 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u044F...
      \u0410 \u0432\u0435\u0434\u044C \u043E\u043D\u0438 \u0443 \u043D\u0438\u0445
      \u043F\u043E\u0434 \u0431\u043E\u043A\u043E\u043C!"
    choices:
    - bad: 0
      text: "\u0412\u044B \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0435, \u0447\u0442\u043E
        \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443 \u0438\u0445
        \u043B\u0430\u0433\u0435\u0440\u044C?"
      nextNode: 4
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u041D\u0435\u0442, \u044F \u0442\u043E\u0447\u043D\u043E \u0443\u0432\u0435\u0440\u0435\u043D,
      \u0447\u0442\u043E \u043E\u043D \u0440\u044F\u0434\u043E\u043C! \u0427\u0443\u0442\u044C
      \u043B\u0438 \u043D\u0435 \u0443 \u0434\u0435\u0440\u0435\u0432\u043D\u0438.
      \u041E\u0434\u0438\u043D \u0438\u0437 \u044D\u0442\u0438\u0445 \u0431\u043E\u043B\u0432\u0430\u043D\u043E\u0432
      \u043E\u0431\u043C\u043E\u043B\u0432\u0438\u043B\u0441\u044F \u043E\u0431 \u044D\u0442\u043E\u043C,
      \u043F\u043E\u043A\u0430 \u043C\u0435\u043D\u044F \u0433\u0440\u0430\u0431\u0438\u043B\u0438.
      (\u0417\u0430\u0434\u0443\u043C\u0430\u043B\u0441\u044F) \u0421\u043B\u0443\u0448\u0430\u0439,
      \u0434\u0430\u0432\u0430\u0439 \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u043C
      \u0441\u0434\u0435\u043B\u043A\u0443? \u0422\u044B \u0432\u0435\u0440\u043D\u0435\u0448\u044C
      \u043C\u043D\u0435 \u043C\u043E\u0438 \u0442\u043E\u0432\u0430\u0440\u044B,
      \u0430 \u044F \u0442\u0435\u0431\u0435 \u043F\u0440\u043E\u0434\u0430\u043C
      \u0447\u0430\u0441\u0442\u044C \u0441\u0432\u043E\u0435\u0433\u043E \u0430\u0440\u0441\u0435\u043D\u0430\u043B\u0430.
      \u0412\u0441\u0435 \u0440\u0430\u0432\u043D\u043E \u044F \u0435\u0433\u043E
      \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
      \u0445\u043E\u0442\u0435\u043B. \u0421\u0434\u0435\u043B\u043A\u0430?"
    choices:
    - bad: 0
      text: "\u0425\u043E\u0440\u043E\u0448\u043E, \u0441\u0434\u0435\u043B\u043A\u0430."
      nextNode: -1
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u0417\u043D\u0430\u044E \u043B\u0438 \u044F? \u041A\u043E\u043D\u0435\u0447\u043D\u043E
      \u0437\u043D\u0430\u044E! \u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B
      \u0432 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0435 \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
      \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441 \u0434\u0435\u043D\u044C\u0433\u0430\u043C\u0438
      \u0438 \u041A\u043E\u0440\u043E\u043D\u0430 \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0430,
      \u0447\u0442\u043E \u0432\u0441\u0435 \u0432\u0430\u0436\u043D\u044B\u0435
      \u0437\u0434\u0430\u043D\u0438\u044F \u0442\u0435\u043F\u0435\u0440\u044C \u043E\u0431\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044E\u0442\u0441\u044F
      \u043D\u0430\u043B\u043E\u0433\u043E\u043C. \u0418\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
      \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u0445
      \u0438\u043B\u0438 \u0442\u0435\u0445, \u043A\u0442\u043E \u044D\u0442\u0438
      \u0434\u0435\u043D\u044C\u0433\u0438, \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E,
      \u0438 \u0434\u0435\u043B\u0430\u0435\u0442, \u043A\u0430\u043A \u044F. \u0411\u043B\u0430\u0433\u043E
      \u044D\u0442\u0438 \u0431\u0430\u043D\u0434\u0438\u0442\u044B \u0445\u043E\u0442\u044F
      \u0431\u044B \u043F\u0440\u043E\u043F\u0443\u0441\u043A \u043D\u0435 \u043D\u0430\u0448\u043B\u0438.
      \u0422\u0443\u043F\u0438\u0446\u044B!"
    choices:
    - bad: 0
      text: "\u0417\u0430 \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u044B
        \u043C\u043D\u0435 \u0434\u0430\u0448\u044C \u043F\u0440\u043E\u043F\u0443\u0441\u043A?"
      nextNode: 6
    - bad: 0
      text: "\u0425\u043E\u0440\u043E\u0448\u043E, \u0442\u0435\u043F\u0435\u0440\u044C
        \u043E\u043D \u043C\u043E\u0439!"
      nextNode: 7
  - speaker: "\u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 "
    dialogue: "\u041D\u0438 \u0437\u0430 \u0441\u043A\u043E\u043B\u044C\u043A\u043E!
      \u042D\u0442\u0438 \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430 \u0432\u044B\u0434\u0430\u044E\u0442\u0441\u044F
      \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437! \u041F\u043E\u0442\u0435\u0440\u044F\u0435\u0448\u044C
      \u0433\u0434\u0435-\u043D\u0438\u0431\u0443\u0434\u044C \u0438 \u0432\u0441\u0435!
      \u0422\u044B \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446,
      \u0430 \u043D\u0435\u0437\u043D\u0430\u043A\u043E\u043C\u0435\u0446 \u043F\u0440\u0438\u043A\u0438\u0434\u044B\u0432\u0430\u044E\u0449\u0438\u0439\u0441\u044F
      \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C! (\u0417\u0430\u0434\u0443\u043C\u044B\u0432\u0430\u0435\u0442\u0441\u044F)
      \u041D\u0430\u0432\u0435\u0440\u043D\u043E\u0435 \u0437\u0440\u044F \u044F
      \u044D\u0442\u043E \u0441\u043A\u0430\u0437\u0430\u043B."
